# Cicero Web Studio environment variables
#
# Local development:
#   npm run env:setup    # copies this file to .env (if missing)
#   Fill in values, then: npm run env:check
#
# Vercel (required for production builds):
#   Pull:  npm run env:pull
#   Push:  Vercel dashboard → Project Settings → Environment Variables → Import .env
#   VITE_* vars must be enabled for Production (they are baked in at build time)
#
# Security:
#   - Never commit real secrets here — use placeholders only
#   - Never prefix secrets with VITE_ (those are bundled into the browser)
#   - RESEND_API_KEY, GOOGLE_SHEETS_WEBHOOK_SECRET stay server-side only

# --- Client (VITE_ = exposed to browser; safe for anon keys only) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_CLIENT_PORTAL_INTAKE_WEBHOOK_URL=/api/client-portal-intake
VITE_CLIENT_PORTAL_UPDATE_WEBHOOK_URL=/api/client-portal-intake
VITE_N8N_WF2_WEBHOOK_URL=https://your-workspace.app.n8n.cloud/webhook/wf2-copy-agent

# --- Server only (API routes on Vercel + local dev middleware) ---
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=you@yourdomain.com
RESEND_FROM_EMAIL=Your Name <you@yourdomain.com>
BUSINESS_POSTAL_ADDRESS=
LEAD_REPLY_TO_EMAIL=
LEAD_UNSUBSCRIBE_URL=

# --- Google Sheets sync ---
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_WEBHOOK_URL=
